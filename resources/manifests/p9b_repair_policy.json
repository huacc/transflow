  "atom_defaults": {
    "applicable_finding_codes": ["P9_TEXT_LAYOUT_OVERFLOW", "TEXT_LAYOUT_OVERFLOW"],
    "required_facts": ["route_capability_match", "translation_complete"],
    "excluded_conditions": ["route_capability_mismatch"],
    "hard_guards": ["owner_violation", "protected_region_violation", "source_text_residual"],
    "apply_adapter": "legacy_repair",
    "bounded_parameters": [
      {"name": "legacy_step", "minimum": 1.0, "maximum": 1.0, "default": 1.0}
    ]
  },
  "comparator_defaults": {
    "metrics": [
      {"name": "overflow", "direction": "MINIMIZE"},
      {"name": "unresolved_hard_findings", "direction": "MINIMIZE"}
    ],
    "hard_rejection_codes": [
      "OWNER_VIOLATION",
      "PROTECTED_REGION_VIOLATION",
      "SOURCE_TEXT_RESIDUAL"
    ],
    "precision": 6,
    "epsilon": 0.000001,
    "tie_policy": "KEEP_CURRENT"
  }
