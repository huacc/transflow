      "comparator_version": "p9b-table-comparator/v1",
      "atoms": [{"atom_id": "body.table.legacy_repair/v1", "priority": 10}]
    },
    {
      "route": "body.anchored_blocks",
      "toolbox_id": "body.anchored_blocks",
