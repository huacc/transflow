      "type": "boolean"
    },
    "evidence_hash": {
      "minLength": 1,
      "type": "string"
    },
    "failure_passed": {
      "type": "boolean"
    },
    "fallback": {
      "minLength": 1,
      "type": "string"
    },
    "fallback_has_complete_pdf": {
      "type": "boolean"
    },
    "fallback_has_page_outcome": {
      "type": "boolean"
    },
    "fixture_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
