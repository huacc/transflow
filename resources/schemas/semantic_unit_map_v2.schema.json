{
  "$id": "transflow.semantic-unit-map/v2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "entries": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "container_id": {"minLength": 1, "type": "string"},
          "disposition": {
            "enum": ["TRANSLATE", "KEEP_SOURCE", "PROTECTED", "UNSUPPORTED", "UNRESOLVED"]
          },
          "disposition_reason": {"type": ["string", "null"]},
          "keep_source_reason": {"type": ["string", "null"]},
          "object_id": {"minLength": 1, "type": "string"},
          "ordinal": {"minimum": 0, "type": "integer"},
          "owner": {"minLength": 1, "type": "string"},
          "required_literals": {"items": {"type": "string"}, "type": "array"},
          "source_hash": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
          "source_object_ids": {
            "items": {"minLength": 1, "type": "string"},
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "source_text": {"minLength": 1, "type": "string"},
          "unit_id": {"minLength": 1, "type": "string"}
        },
        "required": [
          "container_id",
          "disposition",
          "disposition_reason",
          "keep_source_reason",
          "object_id",
          "ordinal",
          "owner",
          "required_literals",
          "source_hash",
          "source_object_ids",
          "source_text",
          "unit_id"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "map_hash": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "map_id": {"minLength": 1, "type": "string"},
    "page_no": {"minimum": 1, "type": "integer"},
    "schema_version": {"const": "transflow.semantic-unit-map/v2"},
    "source_hash": {"pattern": "^[0-9a-f]{64}$", "type": "string"}
  },
  "required": ["entries", "map_hash", "map_id", "page_no", "schema_version", "source_hash"],
  "type": "object"
}
