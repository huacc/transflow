{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.merqfin/pdf-translation-replay-contract.schema.json",
  "title": "PDF Translation Replay Contract",
  "type": "object",
  "required": [
    "contract_id",
    "version",
    "source_pdf",
    "output_pdf",
    "replay_script",
    "toolchain",
    "quality_thresholds"
  ],
  "properties": {
    "contract_id": {"type": "string"},
    "version": {"type": "string"},
    "workspace": {"type": "string"},
    "source_pdf": {"type": "string"},
    "output_pdf": {"type": "string"},
    "output_render": {"type": "string"},
    "replay_script": {"type": "string"},
    "process_document": {"type": "string"},
    "evidence_files": {
      "type": "array",
      "items": {"type": "string"}
    },
    "toolchain": {
      "type": "object",
      "required": ["shell", "python", "pymupdf", "font_regular", "font_light", "font_bold"],
      "properties": {
        "shell": {"type": "string"},
        "python": {"type": "string"},
        "pymupdf": {"type": "string"},
        "font_regular": {"type": "string"},
        "font_light": {"type": "string"},
        "font_bold": {"type": "string"}
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "quality_thresholds": {
      "type": "object",
      "required": [
        "page_count",
        "page_rect",
        "ascii_tokens",
        "fit_warnings",
        "column_y_span_ratio_min",
        "column_y_span_ratio_max",
        "column_area_ratio_min",
        "column_line_count_ratio_min",
        "column_abs_median_gap_delta_max"
      ],
      "properties": {
        "page_count": {"type": "integer"},
        "page_rect": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {"type": "number"}
        },
        "ascii_tokens": {
          "type": "array",
          "items": {"type": "string"}
        },
        "fit_warnings": {"type": "integer"},
        "column_y_span_ratio_min": {"type": "number"},
        "column_y_span_ratio_max": {"type": "number"},
        "column_area_ratio_min": {"type": "number"},
        "column_line_count_ratio_min": {"type": "number"},
        "column_abs_median_gap_delta_max": {"type": "number"}
      }
    },
    "artifact_hashes_sha256": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    }
  }
}
