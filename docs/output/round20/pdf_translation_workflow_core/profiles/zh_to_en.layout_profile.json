  "prompt_overlay": {
    "D2_translation": [
      "Translate into natural English suitable for an annual report.",
      "Do not copy Chinese punctuation rhythm into English; use Western word wrapping and concise paragraphs.",
      "Provide compact English variants for chart labels, table cells, legends, and side navigation."
    ],
    "D4_layout_plan": [
      "For paragraph body copy, treat source bboxes as redaction/order anchors, not hard containers; recompute target visual composition within the current page body band before shrinking font size.",
