{
  "profile_id": "zh_to_en",
  "source_language": "zh",
  "target_language": "en",
  "target_text_field": "translation_en",
  "layout_strategy": "target_visual_composition_before_font_shrink",
  "directional_policy": {
    "direction_specific_dimensions": [
      "fluid body copy usually expands from Chinese into English",
      "English body copy needs Western word wrapping and wider readable frames",
      "mixed image/text pages must keep local event/photo anchors instead of page-wide body composition"
    ],
    "direction_independent_dimensions": [
      "image preservation",
      "background residue detection",
      "table and chart structure",
      "side-navigation glyph orientation",
      "no tiny fallback text for critical roles"
    ]
  },
  "principles": [
    "Use the Chinese source PDF as the only runtime layout anchor.",
    "English target text often expands and needs Western word wrapping, so expand paragraph frames before shrinking font size.",
    "Do not use official English reference pages during generation; use them only after the run for offline comparison."
  ],
  "policy_overrides": {
