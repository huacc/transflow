        "value_amount_regex": "((?:US\\$|HK\\$|\\$|GBP|EUR)?\\s*\\d[\\d,]*(?:\\.\\d+)?\\s*(?:[%\\uFF05]|\\u7f8e\\u5143|\\u6e2f\\u5143|\\u5104\\u5143|\\u4ebf|bn|billion|millions?|m|bps|\\u57fa\\u9ede|\\u57fa\\u70b9)?)|((?:US\\$|HK\\$|\\$|GBP|EUR)\\s*\\d)",
        "anti_overfit": "classify by current-page font hierarchy plus generic numeric/currency/percentage tokens; never by filename, page number, exact value, or fixed point size"
