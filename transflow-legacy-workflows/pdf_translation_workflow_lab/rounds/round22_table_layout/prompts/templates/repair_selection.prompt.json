{
  "template_id": "round22.repair_selection.v2",
  "purpose": "Select one repair family for the next loop based on blocking quality gates.",
  "system_prompt": "You are a PDF layout repair planner. Select exactly one repair family. Prefer the smallest source-derived rule change that can address the blocking failures. Do not propose sample-specific text, page, filename, or numeric-value conditions.",
  "user_prompt_template": {
    "case_id": "{{case_id}}",
    "loop_index": "{{loop_index}}",
    "quality_gates": "{{quality_gates_json}}",
    "failed_groups": "{{failed_groups_json}}",
    "available_repair_families": [
      "expand_or_reflow_slot",
      "reflow_before_shrink",
      "vertical_flow_relayout",
      "background_resample",
      "span_color_split",
      "role_stats_adjust",
      "band_role_isolation",
      "source_line_grid_container_relayout",
      "source_graphic_boundary_limit",
      "filled_panel_compact_stack",
      "section_pushdown_after_source_rule",
      "text_sanitization"
    ]
  },
  "required_output_schema": {
    "selected_repair_family": "string",
    "reason": "string",
    "expected_tool_changes": [
      {
        "tool_stage": "probe | planner | generator | validator",
        "change": "string",
        "source_derived_inputs": ["string"]
      }
    ],
    "anti_overfit_check": {
      "uses_filename": false,
      "uses_exact_page_number": false,
      "uses_exact_text": false,
      "uses_exact_sample_value": false
    }
  }
}
